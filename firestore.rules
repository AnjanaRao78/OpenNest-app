rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function hasFamily() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function sameFamily(resourceData) {
      return signedIn()
        && hasFamily()
        && resourceData.familyId == currentUser().familyId;
    }

    function sameFamilyOnCreate() {
      return signedIn()
        && hasFamily()
        && request.resource.data.familyId == currentUser().familyId;
    }

    function isAuthor(resourceData) {
      return resourceData.authorUid == request.auth.uid;
    }

    function isCreatingOwnDoc() {
      return request.resource.data.authorUid == request.auth.uid;
    }

    // USERS
    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    // GENERIC FAMILY-BASED MODULES
    match /{collection}/{docId} {
      allow read: if sameFamily(resource.data);

      allow create: if isCreatingOwnDoc()
        && sameFamilyOnCreate();

      allow update, delete: if sameFamily(resource.data)
        && isAuthor(resource.data);
    }
  }
}